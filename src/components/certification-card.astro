---
import { Icon } from 'astro-icon/components';
const { cert } = Astro.props;
---

<a href={cert.url} target="_blank" rel="noopener noreferrer" class="block group h-full">
  <div class="cert-card bg-accent/5 border border-accent/10 rounded-xl overflow-hidden hover:border-accent/40 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full shadow-lg hover:shadow-accent/10">
    
    <div class="aspect-[4/3] overflow-hidden relative border-b border-accent/10 bg-white p-4 flex items-center justify-center">
      <img 
        src={cert.image} 
        alt={`Certificado ${cert.title}`} 
        /* Mudado de object-cover para object-contain para mostrar TUDO */
        class="max-w-full max-h-full object-contain opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
        onerror="this.src='/placeholder.jpeg'" 
      />
      <div class="absolute inset-0 bg-background/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-[2px]">
        <div class="p-3 bg-accent rounded-full text-background transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 shadow-xl">
          <Icon name="mdi:open-in-new" class="w-6 h-6" />
        </div>
      </div>
    </div>

    <div class="p-5 flex-1 flex flex-col justify-between bg-accent/5">
      <div>
        <h3 class="font-heading font-bold text-maintext leading-tight group-hover:text-accent transition-colors text-sm md:text-base">{cert.title}</h3>
        <p class="text-subtext text-xs mt-1">{cert.issuer}</p>
      </div>
      <div class="mt-4 flex items-center justify-start">
        <span class="text-[10px] font-bold uppercase tracking-wider text-accent/80 bg-accent/10 px-2 py-1 rounded border border-accent/20">
          {cert.hours}
        </span>
      </div>
    </div>

  </div>
</a>